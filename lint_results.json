mr: {\n      overlay: false,\n    },\n  },\n  plugins: [\n    TanStackRouterVite({\n      autoCodeSplitting: true,\n    }),\n    react(),\n    stripWorkerRefresh(),\n  ],\n  worker: {\n    format: \"es\",\n  },\n  resolve: {\n    alias: {\n      \"@\": path.resolve(__dirname, \"./src\"),\n    },\n  },\n  define: {\n    'global.HowlerGlobal': '{}',\n  },\n}));\n","usedDeprecatedRules":[]},{"filePath":"/Users/amauricia/Documents/GitHub/stable-lords/vitest.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
